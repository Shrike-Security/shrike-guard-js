{
  "name": "shrike-guard",
  "version": "1.3.3",
  "description": "Shrike SDK for AI agent action governance — drop-in wrapper for OpenAI, Anthropic, and Gemini that governs every tool call, prompt, and response server-side. Allow / approve / block. Free tier available.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai/index.d.ts",
      "import": "./dist/openai/index.mjs",
      "require": "./dist/openai/index.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic/index.d.ts",
      "import": "./dist/anthropic/index.mjs",
      "require": "./dist/anthropic/index.js"
    },
    "./gemini": {
      "types": "./dist/gemini/index.d.ts",
      "import": "./dist/gemini/index.mjs",
      "require": "./dist/gemini/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "action-governance",
    "ai-agents",
    "agent-security",
    "agent-governance",
    "tool-call-gating",
    "ai-governance",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "llm",
    "prompt-injection",
    "pii",
    "jailbreak",
    "ai-safety"
  ],
  "author": "Shrike Security <security@shrikesecurity.com>",
  "license": "Apache-2.0",
  "homepage": "https://shrikesecurity.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shrike-Security/shrike-guard-js"
  },
  "bugs": {
    "url": "https://github.com/Shrike-Security/shrike-guard-js/issues"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.18.0",
    "@google/genai": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "openai": "^4.28.0",
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/genai": "^0.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
